# SRH Dashboard — example environment file.
#
# Copy this file to `.env` for local development with `netlify dev`, or set
# the same variables under Site settings → Environment variables in the
# Netlify dashboard for production.
#
# All variables are OPTIONAL: when a credential is missing the matching
# Netlify function returns an empty array and the dashboard renders empty
# states instead of failing. This makes it safe to deploy in stages.

# ---------------------------------------------------------------------------
# ODK Central — live routine submissions
# ---------------------------------------------------------------------------
# Email + password of an ODK Central user with read access to project 1239
# (the SRH Routine Tool form). Used by netlify/functions/odk-data.ts.
ODK_EMAIL=
ODK_PASSWORD=

# Optional override. Defaults to the SRH Routine Tool OData endpoint.
# ODK_BASE_URL=
# ---------------------------------------------------------------------------
# Google Sheets — "Publish to web" CSV URLs (no Google Cloud API key needed)
# ---------------------------------------------------------------------------
# Get each URL by: File → Share → Publish to web → choose "Comma-separated
# values (.csv)" → click Publish → copy the link.
#
# Trade-off: the sheet contents become readable to anyone with the URL.
# Fine for program-aggregate data; don't publish anything with PII / secrets.

GOVERNANCE_CSV_URL=
COMMODITY_CSV_URL=
BASELINE_CSV_URL=

# Header-row index for the baseline sheet (default 1 — technical names on
# row 0, display names on row 1). Set to 0 if your sheet only has display
# names.
# BASELINE_HEADER_ROW=1
